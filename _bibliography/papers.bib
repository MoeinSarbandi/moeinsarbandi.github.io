@article{wes-2025-206,
  abbr        = {WES},
  bibtex_show = {true},
  title       = {Wind speed estimation using second-order sliding-mode observers: simulation and experimental validation on a floating offshore wind turbine},
  author      = {Sarbandi, M. and Viozelange, M. and Hamida, M. A. and Plestan, F.},
  journal     = {Wind Energy Science},
  year        = {2026},
  pages       = {1--26},
  doi         = {10.5194/wes-2025-206},
  url         = {https://wes.copernicus.org/preprints/wes-2025-206/},
  html        = {https://wes.copernicus.org/preprints/wes-2025-206/},
  preview     = {WES.png},
  selected    = {true},
  abstract    = {Rotor-effective wind speed (REWS) estimation is crucial for the control and performance optimization of floating
offshore wind turbines (FOWTs). This paper introduces a robust estimation framework based on second-order sliding-mode
observers (SOSMOs), developed in both constant-gain and adaptive versions. The observers are developed using a reducedorder
dynamic model and validated in the OpenFAST simulation environment when all degrees of freedom are activated.
Their performances are compared with the continuous-discrete extended Kalman filter (CD-EKF) used in the reference opensource
controller (ROSCO). The proposed approach is assessed under stochastic wind/wave conditions through OpenFAST
simulations and further validated experimentally using a scaled software-in-the-loop (SIL) setup. Simulation results indicate
that the proposed observers perform comparably to the CD-EKF in terms of estimation accuracy, while offering robustness,
simpler implementation, and reduced computational complexity.}
}


@article{Sarbandi_2026_jpcs,
  abbr        = {JPCS},
  bibtex_show = {true},
  title       = {Control of Floating Offshore Wind Turbines via Control Lyapunov Function–Based Quadratic Programming and Adaptive Super-Twisting},
  author      = {Sarbandi, M. and Hamida, M. A. and Plestan, F.},
  journal     = {Journal of Physics: Conference Series},
  volume      = {3224},
  number      = {5},
  pages       = {052032},
  year        = {2026},
  month       = {May},
  publisher   = {IOP Publishing},
  doi         = {10.1088/1742-6596/3224/5/052032},
  html        = {https://doi.org/10.1088/1742-6596/3224/5/052032},
  selected    = {false},
  preview     = {TORQUE.png},
  abstract    = {This study presents a robust control method for floating offshore wind turbines (FOWTs) operating in Region III. The approach combines control Lyapunov function–based quadratic programming (CLF–QP) with an adaptive super-twisting (ASTW) algorithm. The controller is designed to maintain power regulation while mitigating structural fatigue via collective blade pitch actuation.}
}

